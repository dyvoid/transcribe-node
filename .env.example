# TranscribeNode runtime configuration.
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
#
# Precedence: a real environment variable > this .env > pyproject.toml > built-in default.

# Host interface to bind to.
#   127.0.0.1  -> localhost only (default, recommended)
#   0.0.0.0    -> reachable from your local network
# WARNING: the API has no authentication. Binding to 0.0.0.0 lets anyone on the
# network call it, including loading/unloading models. Only do this on a trusted network.
TRANSCRIBENODE_HOST=127.0.0.1

# Port to serve the API and UI on.
TRANSCRIBENODE_PORT=9000

# Default model to load when a request does not specify one.
# See the model table in the README for options.
TRANSCRIBENODE_MODEL=large-v3

# Where downloaded models are cached. Relative paths are resolved against the
# project root; absolute paths are used as-is.
TRANSCRIBENODE_MODELS_DIR=models
